---
import type { PostEntry } from "@/utils/posts"
import { postUrl } from "@/utils/posts"

interface Props {
  post: PostEntry
}

const { post } = Astro.props
---

<article
  class="rounded-lg bg-card p-5 transition-colors hover:bg-muted/50"
  data-text-card
>
  <a href={postUrl(post)} class="flex flex-col gap-2">
    <span class="text-xs text-muted-foreground">
      {post.data.pubDate.toLocaleDateString(post.data.locale)}
    </span>
    <h2 class="text-lg font-semibold tracking-tight">{post.data.title}</h2>
    <p class="line-clamp-2 text-sm text-muted-foreground">
      {post.data.description}
    </p>
  </a>
</article>
