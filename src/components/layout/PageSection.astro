---
interface Props {
  class?: string
  pagefindIgnore?: boolean
  [key: string]: unknown
}

const { class: className = "", pagefindIgnore = true, ...attrs } = Astro.props
const pagefindAttrs = pagefindIgnore ? { "data-pagefind-ignore": "" } : {}
---

<section
  class={`mx-auto w-full max-w-6xl px-4 py-6 sm:px-5 md:px-6 ${className}`}
  {...attrs}
  {...pagefindAttrs}
>
  <slot />
</section>
