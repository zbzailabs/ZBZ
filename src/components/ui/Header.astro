---
import type { Locale } from "@/config/locales"
import { getPrimaryCategories, getTagsForCategory } from "@/config/taxonomy"
import { SITE_CONFIG } from "@/config/site"
import { localePath } from "@/utils/routes"
import { t } from "@/utils/translations"
import OptimizedPicture from "@/components/features/OptimizedPicture.astro"
import Icon from "@/components/ui/Icon.astro"
import MobileNav from "@/components/islands/MobileNav.astro"
import LanguageSwitcher from "@/components/islands/LanguageSwitcher.astro"
import ThemeSwitcher from "@/components/islands/ThemeSwitcher.astro"
import logo from "@/assets/logo.svg"

interface Props {
  lang: Locale
  path?: string
}

const { lang, path = "/" } = Astro.props
const primaryCategories = getPrimaryCategories()
---

<header
  class="header-glass relative z-40 w-full"
  data-pagefind-ignore
>
  <div
    class="mx-auto grid h-14 max-w-6xl grid-cols-[minmax(0,1fr)_auto] items-center gap-3 px-4 sm:px-6 lg:grid-cols-[1fr_auto_1fr]"
  >
    <a
      href={localePath(lang, "/")}
      class="flex min-w-0 items-center gap-2.5 justify-self-start text-lg font-semibold text-foreground"
      data-header-brand
    >
      <OptimizedPicture
        src={logo}
        alt={`${SITE_CONFIG.name} logo`}
        width={24}
        height={24}
        widths={[24, 48]}
        sizes="24px"
        class="site-logo size-6"
        loading="eager"
      />
      <span class="truncate" aria-hidden="true">{SITE_CONFIG.name}</span>
    </a>
    <nav
      class="hidden items-center gap-7 justify-self-center text-sm lg:col-start-2 lg:flex"
      aria-label="Primary navigation"
    >
      {
        primaryCategories.map((item) => (
          <div class="group relative py-4">
            <a
              class="nav-link font-medium"
              href={localePath(lang, `/category/${item.slug}/`)}
            >
              {item.labelByLocale[lang]}
            </a>
            <div class="nav-dropdown pointer-events-none absolute top-full left-1/2 grid min-w-48 -translate-x-1/2 translate-y-2 gap-1 rounded-xl p-2 opacity-0 shadow-xl transition-all duration-200 group-focus-within:pointer-events-auto group-focus-within:translate-y-0 group-focus-within:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0 group-hover:opacity-100">
              <a
                class="rounded-lg px-3 py-2 text-sm font-medium text-foreground hover:bg-muted"
                href={localePath(lang, `/category/${item.slug}/`)}
              >
                {item.labelByLocale[lang]}
              </a>
              {getTagsForCategory(item.slug).map((tag) => (
                <a
                  class="rounded-lg px-3 py-2 text-sm text-muted-foreground hover:bg-muted hover:text-foreground"
                  href={localePath(lang, `/tags/${tag.slug}/`)}
                >
                  {tag.labelByLocale[lang]}
                </a>
              ))}
            </div>
          </div>
        ))
      }
      <a class="nav-link font-medium" href={localePath(lang, "/posts/")}>
        {t(lang, "pages.posts.title")}
      </a>
    </nav>
    <div
      class="col-start-2 flex items-center gap-1 justify-self-end sm:gap-2 lg:col-start-3"
      data-header-actions
    >
      <a
        class="inline-flex size-8 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
        href={localePath(lang, "/search/")}
        aria-label="Search"
      >
        <Icon name="search" class="size-4" dataIcon="inline-start" />
      </a>
      <LanguageSwitcher lang={lang} path={path} />
      <ThemeSwitcher lang={lang} />
      <MobileNav lang={lang} />
    </div>
  </div>
</header>
