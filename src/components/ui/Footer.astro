---
import type { Locale } from "@/config/locales"
import Icon from "@/components/ui/Icon.astro"
import OptimizedPicture from "@/components/features/OptimizedPicture.astro"
import { SITE_CONFIG } from "@/config/site"
import { getPrimaryCategories, getTagsForCategory } from "@/config/taxonomy"
import { localePath } from "@/utils/routes"
import { t } from "@/utils/translations"
import logo from "@/assets/logo.svg"

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const primaryCategories = getPrimaryCategories()
const year = new Date().getFullYear()
const legalLinks = [
  { href: localePath(lang, "/about/"), label: t(lang, "pages.about.title") },
  {
    href: localePath(lang, "/privacy-policy/"),
    label: t(lang, "footer.privacyPolicy"),
  },
  {
    href: localePath(lang, "/terms-of-service/"),
    label: t(lang, "footer.termsOfService"),
  },
]
---

<footer class="w-full bg-background" data-pagefind-ignore>
  <div
    class="mx-auto grid max-w-6xl gap-8 px-4 py-12 text-sm text-muted-foreground sm:px-6 md:grid-cols-[1.35fr_3fr] md:gap-16 md:py-16"
  >
    <div class="flex flex-col items-start gap-2 md:min-h-44 md:gap-3">
      <a
        href={localePath(lang, "/")}
        class="flex w-fit items-center gap-2.5 text-xl font-semibold text-foreground"
      >
        <OptimizedPicture
          src={logo}
          alt={`${SITE_CONFIG.name} logo`}
          variant="logo"
          width={28}
          height={28}
          class="size-7"
          loading="lazy"
        />
        <span aria-hidden="true">{SITE_CONFIG.name}</span>
      </a>
      <div class="flex items-center justify-start gap-3">
        <a
          class="inline-flex size-9 items-center justify-center text-muted-foreground transition-colors hover:text-foreground"
          href={SITE_CONFIG.repository}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
        >
          <Icon name="github" class="size-4" dataIcon="inline-start" />
        </a>
        <a
          class="inline-flex size-9 items-center justify-center text-muted-foreground transition-colors hover:text-foreground"
          href={SITE_CONFIG.social.x}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="X"
        >
          <Icon name="x" class="size-4" dataIcon="inline-start" />
        </a>
        <a
          class="inline-flex size-9 items-center justify-center text-muted-foreground transition-colors hover:text-foreground"
          href={`/${lang}/rss.xml`}
          aria-label="RSS"
        >
          <Icon name="rss" class="size-4" dataIcon="inline-start" />
        </a>
      </div>
    </div>
    <div class="mx-auto grid w-full max-w-sm grid-cols-2 gap-x-8 gap-y-9 md:mx-0 md:max-w-none md:grid-cols-4 md:gap-x-10 md:gap-y-10">
      {
        primaryCategories.map((category) => (
          <nav
            class="grid w-full content-start gap-4 text-left md:w-fit md:justify-self-start"
            aria-label={category.labelByLocale[lang]}
          >
            <a
              class="text-base font-semibold text-foreground transition-colors hover:text-foreground/75"
              href={localePath(lang, `/category/${category.slug}/`)}
            >
              {category.labelByLocale[lang]}
            </a>
            {getTagsForCategory(category.slug).map((tag) => (
              <a
                class="text-[0.9375rem] leading-6 transition-colors hover:text-foreground"
                href={localePath(lang, `/tags/${tag.slug}/`)}
              >
                {tag.labelByLocale[lang]}
              </a>
            ))}
          </nav>
        ))
      }
      <nav
        class="grid w-full content-start gap-4 text-left md:w-fit md:justify-self-start"
        aria-label={t(lang, "footer.more")}
      >
        <p class="text-base font-semibold text-foreground">
          {t(lang, "footer.more")}
        </p>
        <a
          class="text-[0.9375rem] leading-6 transition-colors hover:text-foreground"
          href={localePath(lang, "/category/")}
        >
          {t(lang, "footer.categories")}
        </a>
        <a
          class="text-[0.9375rem] leading-6 transition-colors hover:text-foreground"
          href={localePath(lang, "/tags/")}
        >
          {t(lang, "footer.tags")}
        </a>
        <a
          class="text-[0.9375rem] leading-6 transition-colors hover:text-foreground"
          href={localePath(lang, "/author/")}
        >
          {t(lang, "footer.author")}
        </a>
      </nav>
    </div>
    <div
      class="flex flex-col items-center gap-4 pt-8 text-center text-xs font-medium md:col-span-2 md:flex-row md:justify-between md:text-left"
    >
      <nav
        class="flex flex-wrap items-center justify-center gap-x-5 gap-y-3 md:justify-start"
        aria-label={`${SITE_CONFIG.name} legal`}
      >
        {
          legalLinks.map((link) => (
            <a class="transition-colors hover:text-foreground" href={link.href}>
              {link.label}
            </a>
          ))
        }
      </nav>
      <p class="text-xs text-muted-foreground">© {year} {SITE_CONFIG.name}</p>
    </div>
  </div>
</footer>
