---
import OptimizedPicture from "@/components/features/OptimizedPicture.astro"
import { getCategory } from "@/config/taxonomy"
import type { PostEntry } from "@/utils/posts"
import { postCategorySlug, postUrl } from "@/utils/posts"

interface Props {
  posts: PostEntry[]
}

const { posts } = Astro.props
const cards = posts.slice(0, 3)
---

{
  cards.length > 0 && (
    <div class="grid grid-cols-12 gap-4 sm:gap-5 lg:h-[36rem] lg:grid-cols-[minmax(0,2.05fr)_minmax(20rem,0.95fr)] lg:grid-rows-2 lg:gap-8">
      {cards.map((post, index) => {
        const categorySlug = postCategorySlug(post)
        const category = getCategory(categorySlug)
        const categoryLabel =
          category?.labelByLocale[post.data.locale] ?? categorySlug
        const dateLabel = new Intl.DateTimeFormat(post.data.locale, {
          month: "short",
          day: "numeric",
          year: "numeric",
        }).format(post.data.pubDate)
        const isLead = index === 0
        const TitleTag = isLead ? "h2" : "h3"

        return (
          <article
            class:list={[
              "post-card group relative col-span-12 aspect-[3/4] w-full min-w-0 max-w-full overflow-hidden rounded-3xl bg-muted text-white sm:min-h-[24rem]",
              isLead
                ? "sm:aspect-[16/9] sm:min-h-[27rem] lg:col-span-1 lg:row-span-2 lg:aspect-auto lg:min-h-0 lg:rounded-[1.75rem]"
                : "sm:col-span-6 lg:col-span-1 lg:aspect-auto lg:min-h-0 lg:rounded-[1.75rem]",
            ]}
            data-glass-card
          >
            <a
              href={postUrl(post)}
              class="absolute inset-0 z-20"
              aria-label={post.data.title}
            />
            <OptimizedPicture
              src={post.data.heroImage}
              alt={post.data.heroImageAlt}
              width={post.data.heroImageWidth}
              height={post.data.heroImageHeight}
              widths={isLead ? [640, 960, 1200, 1600] : [420, 640, 768, 960]}
              sizes={
                isLead
                  ? "(max-width: 639px) calc(100vw - 2rem), (max-width: 1023px) calc(100vw - 3rem), min(64vw, 960px)"
                  : "(max-width: 639px) calc(100vw - 2rem), (max-width: 1023px) 50vw, min(32vw, 448px)"
              }
              priority
              loading="eager"
              fetchpriority="high"
              class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-700 ease-out"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/5" />
            <div
              class:list={[
                "post-card__content absolute z-10 text-center text-white",
                isLead
                  ? "inset-x-1.5 bottom-1.5 rounded-2xl p-4 sm:p-6 lg:rounded-[1.35rem] lg:p-8"
                  : "inset-x-1.5 bottom-1.5 rounded-2xl p-4 sm:p-5",
              ]}
              data-glass-target
            >
              <div
                class="mb-3 flex w-full items-center justify-center gap-3 text-xs text-white/75"
              >
                <span class="card-meta-pill" data-category={categorySlug}>
                  {categoryLabel}
                </span>
                <time
                  class="shrink-0 text-end"
                  datetime={post.data.pubDate.toISOString()}
                >
                  {dateLabel}
                </time>
              </div>
              <TitleTag
                class:list={[
                  "mx-auto font-semibold leading-tight tracking-tight",
                  isLead
                    ? "line-clamp-2 max-w-4xl text-xl"
                    : "line-clamp-2 text-xl",
                ]}
              >
                {post.data.title}
              </TitleTag>
              {isLead && (
                <p class="mx-auto mt-3 line-clamp-3 max-w-5xl text-base leading-7 text-white/80">
                  {post.data.description}
                </p>
              )}
            </div>
          </article>
        )
      })}
    </div>
  )
}
