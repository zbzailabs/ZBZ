---
import PostCardCover from "@/components/cards/PostCardCover.astro"
import type { PostEntry } from "@/utils/posts"

interface Props {
  posts: PostEntry[]
  columns?: "responsive" | "three" | "tablet-three"
  balanceLastRow?: boolean
  priorityFirst?: boolean
  headingLevel?: 2 | 3
  class?: string
  [key: string]: unknown
}

const {
  posts,
  columns = "responsive",
  balanceLastRow = false,
  priorityFirst = false,
  headingLevel = 2,
  class: className = "",
  ...attrs
} = Astro.props
const gridClass =
  columns === "three"
    ? "grid grid-cols-12 gap-5 lg:gap-6"
    : "grid grid-cols-12 gap-4 sm:gap-5 lg:gap-6"
const cardClass =
  columns === "tablet-three"
    ? "col-span-12 sm:col-span-6 md:col-span-4 lg:col-span-4"
    : columns === "three"
      ? "col-span-12 md:col-span-6 lg:col-span-4"
      : "col-span-12 sm:col-span-6 lg:col-span-4"
const shouldBalanceLastRow =
  balanceLastRow && columns === "responsive" && posts.length % 2 === 1
const balancedLastCardClass =
  "sm:col-span-12 sm:!aspect-[16/9] sm:!min-h-[20rem] lg:col-span-4 lg:!aspect-[3/4] lg:!min-h-[24rem]"
---

<div class={`${gridClass} ${className}`} {...attrs}>
  {
    posts.map((post, index) => (
      <PostCardCover
        post={post}
        variant="portrait"
        priority={priorityFirst && index === 0}
        headingLevel={headingLevel}
        class={`${cardClass} ${
          shouldBalanceLastRow && index === posts.length - 1
            ? balancedLastCardClass
            : ""
        }`}
      />
    ))
  }
</div>
