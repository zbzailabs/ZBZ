---
import PostCardText from "@/components/cards/PostCardText.astro"
import type { PostEntry } from "@/utils/posts"

interface Props {
  posts: PostEntry[]
  class?: string
}

const { posts, class: className = "" } = Astro.props
---

<div class={`grid grid-cols-1 gap-5 sm:grid-cols-3 ${className}`}>
  {posts.map((post) => <PostCardText post={post} />)}
</div>
