<script is:inline>
  ;(() => {
    window.__dynamicGlassCleanup?.()

    const CONFIG = {
      sampleSize: 10,
      colorMultiplier: 0.7,
      baseOpacity: 0.24,
      blurAmount: "14px",
    }
    const colorCache = new WeakMap()

    function extractDominantColor(img) {
      if (colorCache.has(img)) return colorCache.get(img)
      const canvas = document.createElement("canvas")
      const ctx = canvas.getContext("2d", { willReadFrequently: true })
      if (!ctx) return null
      canvas.width = CONFIG.sampleSize
      canvas.height = CONFIG.sampleSize
      try {
        ctx.drawImage(img, 0, 0, CONFIG.sampleSize, CONFIG.sampleSize)
        const data = ctx.getImageData(
          0,
          0,
          CONFIG.sampleSize,
          CONFIG.sampleSize
        ).data
        let r = 0
        let g = 0
        let b = 0
        let count = 0
        for (let i = 0; i < data.length; i += 4) {
          const pr = data[i]
          const pg = data[i + 1]
          const pb = data[i + 2]
          const brightness = (pr + pg + pb) / 3
          if (brightness <= 30 || brightness >= 220) continue
          const saturation =
            Math.max(pr, pg, pb) === 0
              ? 0
              : (Math.max(pr, pg, pb) - Math.min(pr, pg, pb)) /
                Math.max(pr, pg, pb)
          const weight = 1 + saturation
          r += pr * weight
          g += pg * weight
          b += pb * weight
          count += weight
        }
        if (!count) return null
        const color = `rgba(${Math.round((r / count) * CONFIG.colorMultiplier)}, ${Math.round((g / count) * CONFIG.colorMultiplier)}, ${Math.round((b / count) * CONFIG.colorMultiplier)}, ${CONFIG.baseOpacity})`
        colorCache.set(img, color)
        return color
      } catch {
        return null
      }
    }

    function apply(card) {
      const img = card.querySelector("img")
      const content = card.querySelector("[data-glass-target]")
      if (!img || !content) return
      const run = () => {
        const color = extractDominantColor(img)
        if (!color) return
        content.style.backgroundColor = color
        content.style.backdropFilter = `blur(${CONFIG.blurAmount})`
        content.style.webkitBackdropFilter = `blur(${CONFIG.blurAmount})`
      }
      if (img.complete && img.naturalWidth > 0) requestAnimationFrame(run)
      else img.addEventListener("load", run, { once: true })
    }

    let observer

    function init() {
      observer?.disconnect()
      observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue
            apply(entry.target)
            observer.unobserve(entry.target)
          }
        },
        { rootMargin: "100px" }
      )
      document
        .querySelectorAll("[data-glass-card]")
        .forEach((card) => observer.observe(card))
    }

    function scheduleInit() {
      const run = () => requestAnimationFrame(init)
      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(run, { timeout: 1500 })
      } else {
        window.setTimeout(run, 600)
      }
    }

    const handlePageLoad = () => scheduleInit()
    const handleBeforeSwap = () => observer?.disconnect()
    document.addEventListener("astro:page-load", handlePageLoad)
    document.addEventListener("astro:before-swap", handleBeforeSwap)
    window.__dynamicGlassCleanup = () => {
      document.removeEventListener("astro:page-load", handlePageLoad)
      document.removeEventListener("astro:before-swap", handleBeforeSwap)
      observer?.disconnect()
    }
    scheduleInit()
  })()
</script>
