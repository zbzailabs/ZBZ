---
import { Image, Picture } from "astro:assets"
import type { ImageMetadata } from "astro"

type ImageLayout = "constrained" | "full-width" | "fixed" | "none"
type ImageFit = "contain" | "cover" | "fill" | "none" | "scale-down"
type ImageQuality = "low" | "mid" | "high" | "max" | number
type ImageVariant =
  | "homeLead"
  | "articleHero"
  | "cardPortrait"
  | "cardWide"
  | "avatar"
  | "logo"
  | "content"

interface ImagePreset {
  layout: ImageLayout
  fit: ImageFit
  position: string
  quality: ImageQuality
  asPicture: boolean
}

const IMAGE_PRESETS = {
  homeLead: {
    layout: "constrained",
    fit: "cover",
    position: "center",
    quality: "high",
    asPicture: false,
  },
  articleHero: {
    layout: "constrained",
    fit: "cover",
    position: "center",
    quality: "mid",
    asPicture: false,
  },
  cardPortrait: {
    layout: "constrained",
    fit: "cover",
    position: "center",
    quality: "mid",
    asPicture: false,
  },
  cardWide: {
    layout: "constrained",
    fit: "cover",
    position: "center",
    quality: "mid",
    asPicture: false,
  },
  avatar: {
    layout: "fixed",
    fit: "cover",
    position: "center",
    quality: "high",
    asPicture: false,
  },
  logo: {
    layout: "fixed",
    fit: "contain",
    position: "center",
    quality: "max",
    asPicture: false,
  },
  content: {
    layout: "constrained",
    fit: "cover",
    position: "center",
    quality: "mid",
    asPicture: false,
  },
} as const satisfies Record<ImageVariant, ImagePreset>

const resolveImageDimensions = (
  source: string | ImageMetadata,
  imageWidth?: number,
  imageHeight?: number,
  useInferSize = false
): { width: number; height: number } | undefined => {
  if (typeof source === "string") {
    if (useInferSize) {
      return undefined
    }

    if (!imageWidth || !imageHeight) {
      throw new Error(
        "Remote images require width and height from content metadata or inferSize."
      )
    }

    return { width: imageWidth, height: imageHeight }
  }

  return {
    width: imageWidth ?? source.width,
    height: imageHeight ?? source.height,
  }
}

interface Props {
  src: string | ImageMetadata
  alt: string
  variant?: ImageVariant
  width?: number
  height?: number
  sizes?: string
  layout?: ImageLayout
  fit?: ImageFit
  position?: string
  quality?: ImageQuality
  asPicture?: boolean
  inferSize?: boolean
  formats?: ("avif" | "webp")[]
  fallbackFormat?: "avif" | "webp" | "jpeg" | "jpg" | "png"
  format?: "avif" | "webp" | "jpeg" | "jpg" | "png"
  class?: string
  priority?: boolean
  loading?: "eager" | "lazy"
  decoding?: "async" | "sync" | "auto"
  fetchpriority?: "high" | "low" | "auto"
}

const props = Astro.props as Props
const {
  src,
  alt,
  variant = "content",
  width,
  height,
  sizes,
  layout,
  fit,
  position,
  quality,
  asPicture,
  inferSize = false,
  formats,
  fallbackFormat,
  format,
  class: className,
  priority = false,
  loading,
  decoding,
  fetchpriority,
} = props

const preset = IMAGE_PRESETS[variant]
const isStringSource = typeof src === "string"
const stringSrc = isStringSource ? (src as string) : undefined
const isRemoteImage = isStringSource ? /^https?:\/\//.test(stringSrc as string) : false
const assetFormat = isStringSource ? undefined : (src as ImageMetadata).format
const isSvgImage = isStringSource
  ? stringSrc?.toLowerCase().split("?")[0]?.endsWith(".svg")
  : assetFormat === "svg"
const dimensions =
  isSvgImage || (isStringSource && inferSize)
    ? undefined
    : resolveImageDimensions(src, width, height, inferSize)
const imageLayout = layout ?? preset.layout
const imageFit = fit ?? preset.fit
const imagePosition = position ?? preset.position
const imageQuality = quality ?? preset.quality
const shouldRenderPicture = asPicture ?? preset.asPicture
const loadingAttrs = {
  priority: priority ? true : undefined,
  loading: loading ?? (priority ? "eager" : "lazy"),
  decoding: decoding ?? "async",
  fetchpriority: fetchpriority ?? (priority ? "high" : undefined),
}
const crossOrigin = isRemoteImage ? "anonymous" : undefined
const imageFormats = formats ?? ["avif", "webp"]
const imageFallbackFormat = fallbackFormat ?? "webp"
const imageFormat = format ?? "avif"
const svgSrc = isStringSource ? (src as string) : (src as ImageMetadata).src
---

{
  isSvgImage ? (
    <img
      src={svgSrc}
      alt={alt}
      width={width}
      height={height}
      loading={loadingAttrs.loading}
      decoding={loadingAttrs.decoding}
      fetchpriority={loadingAttrs.fetchpriority}
      crossorigin={crossOrigin}
      class={className}
    />
  ) : isStringSource && inferSize && shouldRenderPicture ? (
    <Picture
      src={stringSrc as string}
      alt={alt}
      inferSize
      priority={loadingAttrs.priority}
      loading={loadingAttrs.loading}
      decoding={loadingAttrs.decoding}
      fetchpriority={loadingAttrs.fetchpriority}
      crossorigin={crossOrigin}
      class={className}
      formats={imageFormats}
      fallbackFormat={imageFallbackFormat}
      sizes={sizes}
      layout={imageLayout}
      fit={imageFit}
      position={imagePosition}
      quality={imageQuality}
    />
  ) : isStringSource && shouldRenderPicture ? (
    <Picture
      src={stringSrc as string}
      alt={alt}
      width={dimensions?.width as number}
      height={dimensions?.height as number}
      priority={loadingAttrs.priority}
      loading={loadingAttrs.loading}
      decoding={loadingAttrs.decoding}
      fetchpriority={loadingAttrs.fetchpriority}
      crossorigin={crossOrigin}
      class={className}
      formats={imageFormats}
      fallbackFormat={imageFallbackFormat}
      sizes={sizes}
      layout={imageLayout}
      fit={imageFit}
      position={imagePosition}
      quality={imageQuality}
    />
  ) : isStringSource && inferSize ? (
    <Image
      src={stringSrc as string}
      alt={alt}
      inferSize
      priority={loadingAttrs.priority}
      loading={loadingAttrs.loading}
      decoding={loadingAttrs.decoding}
      fetchpriority={loadingAttrs.fetchpriority}
      crossorigin={crossOrigin}
      class={className}
      sizes={sizes}
      layout={imageLayout}
      fit={imageFit}
      position={imagePosition}
      quality={imageQuality}
      format={imageFormat}
    />
  ) : isStringSource ? (
    <Image
      src={stringSrc as string}
      alt={alt}
      width={dimensions?.width as number}
      height={dimensions?.height as number}
      priority={loadingAttrs.priority}
      loading={loadingAttrs.loading}
      decoding={loadingAttrs.decoding}
      fetchpriority={loadingAttrs.fetchpriority}
      crossorigin={crossOrigin}
      class={className}
      sizes={sizes}
      layout={imageLayout}
      fit={imageFit}
      position={imagePosition}
      quality={imageQuality}
      format={imageFormat}
    />
  ) : shouldRenderPicture ? (
    <Picture
      src={src as ImageMetadata}
      alt={alt}
      width={dimensions?.width as number}
      height={dimensions?.height as number}
      priority={loadingAttrs.priority}
      loading={loadingAttrs.loading}
      decoding={loadingAttrs.decoding}
      fetchpriority={loadingAttrs.fetchpriority}
      crossorigin={crossOrigin}
      class={className}
      formats={imageFormats}
      fallbackFormat={imageFallbackFormat}
      sizes={sizes}
      layout={imageLayout}
      fit={imageFit}
      position={imagePosition}
      quality={imageQuality}
    />
  ) : (
    <Image
      src={src as ImageMetadata}
      alt={alt}
      width={dimensions?.width as number}
      height={dimensions?.height as number}
      priority={loadingAttrs.priority}
      loading={loadingAttrs.loading}
      decoding={loadingAttrs.decoding}
      fetchpriority={loadingAttrs.fetchpriority}
      crossorigin={crossOrigin}
      class={className}
      sizes={sizes}
      layout={imageLayout}
      fit={imageFit}
      position={imagePosition}
      quality={imageQuality}
      format={imageFormat}
    />
  )
}
