---
import { getLocaleMeta, type Locale } from "@/config/locales"
import { t } from "@/utils/translations"

interface Props {
  lang: Locale
  id?: string
  label?: string
  class?: string
}

const {
  lang,
  id = "search-page",
  label = t(lang, "search.region"),
  class: className = "",
} = Astro.props
const hint = getLocaleMeta(lang).searchHint
---

<div
  class={`search-shell w-full ${className}`}
  role="search"
  aria-label={label}
>
  <div
    id={id}
    class="pagefind-ui pagefind-init w-full"
    data-locale={lang}
    data-pagefind-search
  >
    <p
      class="rounded-lg bg-background/70 p-6 text-sm text-muted-foreground shadow-sm backdrop-blur-md"
    >
      {hint}
    </p>
  </div>
</div>
<link href={`/pagefind/${lang}/pagefind-ui.css`} rel="stylesheet" />
<script>
  // @ts-nocheck -- Pagefind publishes its browser API at runtime
  ;(() => {
    window.__pagefindSearchCleanup?.()

    const ensurePagefindUI = (bundlePath) => {
      if (window.PagefindUI) return Promise.resolve()
      const existing = document.querySelector("script[data-pagefind-ui-script]")
      if (existing) {
        return new Promise((resolve, reject) => {
          existing.addEventListener("load", resolve, { once: true })
          existing.addEventListener("error", reject, { once: true })
        })
      }
      return new Promise((resolve, reject) => {
        const script = document.createElement("script")
        script.src = `${bundlePath}pagefind-ui.js`
        script.async = true
        script.dataset.pagefindUiScript = "true"
        script.addEventListener("load", resolve, { once: true })
        script.addEventListener("error", reject, { once: true })
        document.head.appendChild(script)
      })
    }

    const initPagefindSearch = async () => {
      const target = document.querySelector("[data-pagefind-search]")
      if (!target) return
      if (target.dataset.pagefindStatus === "loading") return
      const id = target.id
      const lang = target.dataset.locale
      const bundlePath = `/pagefind/${lang}/`

      const activeSearch = window.__pagefindSearch
      if (
        activeSearch?.instance &&
        (activeSearch.locale !== lang || activeSearch.id !== id)
      ) {
        activeSearch.instance.destroy?.()
        window.__pagefindSearch = undefined
      }

      if (
        target.dataset.pagefindLocale === lang &&
        target.querySelector(".pagefind-ui__search-input")
      ) {
        target.dataset.pagefindStatus = "ready"
        return
      }

      target.dataset.pagefindStatus = "loading"
      target.dataset.pagefindLocale = lang
      const fallback = target.innerHTML

      try {
        await ensurePagefindUI(bundlePath)
        target.innerHTML = ""
        const PagefindUI = window.PagefindUI
        if (!PagefindUI) throw new Error("Pagefind UI failed to load.")
        const instance = new PagefindUI({
          element: `#${id}`,
          bundlePath,
          showImages: false,
          showSubResults: true,
        })
        window.__pagefindSearch = { id, instance, locale: lang }

        window.requestAnimationFrame(() => {
          if (target.querySelector(".pagefind-ui__search-input")) {
            target.dataset.pagefindStatus = "ready"
            return
          }
          target.innerHTML = fallback
          target.dataset.pagefindStatus = "fallback"
          window.__pagefindSearch = undefined
        })
      } catch {
        target.innerHTML = fallback
        target.dataset.pagefindStatus = "fallback"
        target.dataset.pagefindLocale = ""
        window.__pagefindSearch = undefined
      }
    }

    const cleanup = () => {
      window.__pagefindSearch?.instance?.destroy?.()
      window.__pagefindSearch = undefined
    }
    const handleBeforeSwap = () => cleanup()
    document.addEventListener("astro:page-load", initPagefindSearch)
    document.addEventListener("astro:before-swap", handleBeforeSwap)
    window.__pagefindSearchCleanup = () => {
      document.removeEventListener("astro:page-load", initPagefindSearch)
      document.removeEventListener("astro:before-swap", handleBeforeSwap)
      cleanup()
    }
    initPagefindSearch()
  })()
</script>
