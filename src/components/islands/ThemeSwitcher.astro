---
import type { Locale } from "@/config/locales"
import Icon from "@/components/ui/Icon.astro"
import { t } from "@/utils/translations"

interface Props {
  lang: Locale
}

const { lang } = Astro.props
---

<div class="relative" data-dropdown-menu>
  <button
    type="button"
    class="inline-flex size-11 items-center justify-center rounded-lg text-muted-foreground transition active:scale-95 active:bg-muted hover:bg-muted hover:text-foreground focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
    aria-label={t(lang, "theme.toggle")}
    aria-expanded="false"
    aria-controls="theme-options"
    data-dropdown-menu-trigger
  >
    <span data-theme-trigger-icon="light">
      <Icon name="sun" class="size-4" dataIcon="inline-start" />
    </span>
    <span class="hidden" data-theme-trigger-icon="dark">
      <Icon name="moon" class="size-4" dataIcon="inline-start" />
    </span>
    <span class="hidden" data-theme-trigger-icon="system">
      <Icon name="monitor" class="size-4" dataIcon="inline-start" />
    </span>
  </button>
  <ul
    id="theme-options"
    class="nav-dropdown absolute top-full end-0 z-50 mt-2 grid w-44 gap-1 rounded-xl p-2 shadow-xl"
    hidden
    data-dropdown-menu-content
  >
    <li>
      <button
        type="button"
        class="flex min-h-11 w-full items-center gap-2 rounded-lg px-3 text-sm whitespace-nowrap text-foreground active:bg-muted hover:bg-muted focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring aria-pressed:bg-muted aria-pressed:font-medium"
        aria-pressed="false"
        data-theme-value="light"
      >
        <Icon name="sun" class="size-4" dataIcon="inline-start" />
        <span>{t(lang, "theme.light")}</span>
      </button>
    </li>
    <li>
      <button
        type="button"
        class="flex min-h-11 w-full items-center gap-2 rounded-lg px-3 text-sm whitespace-nowrap text-foreground active:bg-muted hover:bg-muted focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring aria-pressed:bg-muted aria-pressed:font-medium"
        aria-pressed="false"
        data-theme-value="dark"
      >
        <Icon name="moon" class="size-4" dataIcon="inline-start" />
        <span>{t(lang, "theme.dark")}</span>
      </button>
    </li>
    <li>
      <button
        type="button"
        class="flex min-h-11 w-full items-center gap-2 rounded-lg px-3 text-sm whitespace-nowrap text-foreground active:bg-muted hover:bg-muted focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring aria-pressed:bg-muted aria-pressed:font-medium"
        aria-pressed="false"
        data-theme-value="system"
      >
        <Icon name="monitor" class="size-4" dataIcon="inline-start" />
        <span>{t(lang, "theme.system")}</span>
      </button>
    </li>
  </ul>
</div>

<script>
  // @ts-nocheck -- existing browser controller, bundled to satisfy CSP
  ;(() => {
    window.__themeSwitcherCleanup?.()

    const getThemePreference = () => localStorage.getItem("theme") || "system"
    const darkModeQuery = matchMedia("(prefers-color-scheme: dark)")

    const updateThemeOptions = (theme) => {
      document.querySelectorAll("[data-theme-value]").forEach((option) => {
        if (!(option instanceof HTMLElement)) return
        const selected = option.dataset.themeValue === theme
        if (selected) {
          option.setAttribute("aria-pressed", "true")
          return
        }
        option.setAttribute("aria-pressed", "false")
      })
    }

    const updateThemeTriggerIcon = (theme) => {
      document.querySelectorAll("[data-theme-trigger-icon]").forEach((icon) => {
        if (!(icon instanceof HTMLElement)) return
        icon.classList.toggle(
          "hidden",
          icon.dataset.themeTriggerIcon !== theme,
        )
      })
    }

    const applyTheme = (theme = getThemePreference()) => {
      if (theme === "system") {
        localStorage.removeItem("theme")
      } else {
        localStorage.setItem("theme", theme)
      }
      const resolved =
        theme === "system"
          ? darkModeQuery.matches
            ? "dark"
            : "light"
          : theme
      document.documentElement.classList.toggle("dark", resolved === "dark")
      updateThemeOptions(theme)
      updateThemeTriggerIcon(theme)
    }

    applyTheme()

    const handleClick = (event) => {
      const target = event.target
      if (!(target instanceof Element)) return
      const option = target.closest("[data-theme-value]")
      if (!(option instanceof HTMLElement)) return
      applyTheme(option.dataset.themeValue || "system")
      const menu = option.closest("[data-dropdown-menu]")
      const trigger = menu?.querySelector("[data-dropdown-menu-trigger]")
      const content = menu?.querySelector("[data-dropdown-menu-content]")
      if (trigger instanceof HTMLElement) {
        trigger.setAttribute("aria-expanded", "false")
        trigger.focus()
      }
      if (content instanceof HTMLElement) content.hidden = true
    }

    const handleSystemThemeChange = () => {
      if (getThemePreference() === "system") applyTheme("system")
    }
    const handlePageLoad = () => applyTheme()
    document.addEventListener("click", handleClick)
    document.addEventListener("astro:page-load", handlePageLoad)
    darkModeQuery.addEventListener("change", handleSystemThemeChange)
    window.__themeSwitcherCleanup = () => {
      document.removeEventListener("click", handleClick)
      document.removeEventListener("astro:page-load", handlePageLoad)
      darkModeQuery.removeEventListener("change", handleSystemThemeChange)
    }
  })()
</script>
