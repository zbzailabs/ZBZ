---
import { LOCALE_META, LOCALES, type Locale } from "@/config/locales"
import { localePath } from "@/utils/routes"
import { t } from "@/utils/translations"

interface Props {
  lang: Locale
  path?: string
}

const { lang, path = "/" } = Astro.props
const flags: Record<Locale, string> = {
  zh: "🇨🇳",
  en: "🇺🇸",
  fr: "🇫🇷",
  es: "🇪🇸",
  ru: "🇷🇺",
  ja: "🇯🇵",
  ko: "🇰🇷",
  pt: "🇵🇹",
  de: "🇩🇪",
  id: "🇮🇩",
  ar: "🇸🇦",
}
---

<div class="relative" data-dropdown-menu>
  <button
    type="button"
    class="heos-press inline-flex size-11 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-muted hover:text-foreground focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
    aria-label={t(lang, "language.switch")}
    aria-expanded="false"
    aria-controls="language-options"
    data-dropdown-menu-trigger
  >
    <span class="text-sm leading-none" aria-hidden="true">{flags[lang]}</span>
  </button>
  <div
    id="language-options"
    class="nav-dropdown absolute top-full end-0 z-50 mt-2 grid w-44 gap-1 rounded-xl p-2 shadow-xl"
    role="group"
    aria-label={t(lang, "language.switch")}
    hidden
    data-dropdown-menu-content
  >
    {
      LOCALES.map((locale) => (
        <a
          class="flex min-h-11 items-center gap-2 rounded-lg px-3 text-sm text-foreground hover:bg-muted focus:bg-muted focus:outline-none"
          href={localePath(locale, path)}
          aria-current={locale === lang ? "page" : undefined}
        >
          <span aria-hidden="true">{flags[locale]}</span>
          <span>{LOCALE_META[locale].nativeName}</span>
        </a>
      ))
    }
  </div>
</div>

<script>
  // @ts-nocheck -- existing browser controller, bundled to satisfy CSP
  ;(() => {
    window.__dropdownMenuCleanup?.()

    const closeMenu = (menu, restoreFocus = false) => {
      const trigger = menu.querySelector("[data-dropdown-menu-trigger]")
      const content = menu.querySelector("[data-dropdown-menu-content]")
      if (
        !(trigger instanceof HTMLElement) ||
        !(content instanceof HTMLElement)
      )
        return
      const wasOpen = !content.hidden
      trigger.setAttribute("aria-expanded", "false")
      content.hidden = true
      if (restoreFocus && wasOpen) trigger.focus()
    }

    const closeAll = (except, restoreFocus = false) => {
      document.querySelectorAll("[data-dropdown-menu]").forEach((menu) => {
        if (menu !== except) closeMenu(menu, restoreFocus)
      })
    }

    const openMenu = (menu) => {
      const trigger = menu.querySelector("[data-dropdown-menu-trigger]")
      const content = menu.querySelector("[data-dropdown-menu-content]")
      if (
        !(trigger instanceof HTMLElement) ||
        !(content instanceof HTMLElement)
      )
        return
      closeAll(menu)
      trigger.setAttribute("aria-expanded", "true")
      content.hidden = false
    }

    const handleClick = (event) => {
      const target = event.target
      if (!(target instanceof Element)) return

      const trigger = target.closest("[data-dropdown-menu-trigger]")
      if (trigger instanceof HTMLElement) {
        const menu = trigger.closest("[data-dropdown-menu]")
        const content = menu?.querySelector("[data-dropdown-menu-content]")
        if (!(menu instanceof HTMLElement) || !(content instanceof HTMLElement))
          return
        if (content.hidden) openMenu(menu)
        else closeMenu(menu)
        return
      }

      if (!target.closest("[data-dropdown-menu]")) closeAll(undefined, true)
    }

    const handleKeydown = (event) => {
      if (event.key !== "Escape") return
      const openMenuContent = document.querySelector(
        "[data-dropdown-menu-content]:not([hidden])"
      )
      const menu = openMenuContent?.closest("[data-dropdown-menu]")
      if (!(menu instanceof HTMLElement)) return
      closeMenu(menu, true)
    }

    const handleBeforeSwap = () => closeAll()
    document.addEventListener("click", handleClick)
    document.addEventListener("keydown", handleKeydown)
    document.addEventListener("astro:before-swap", handleBeforeSwap)
    window.__dropdownMenuCleanup = () => {
      document.removeEventListener("click", handleClick)
      document.removeEventListener("keydown", handleKeydown)
      document.removeEventListener("astro:before-swap", handleBeforeSwap)
    }
  })()
</script>
