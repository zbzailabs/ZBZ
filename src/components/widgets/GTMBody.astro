---
import { SITE_CONFIG } from "@/config/site"

const { enabled, containerId } = SITE_CONFIG.analytics.googleTagManager
const shouldRender = enabled && containerId.length > 0
const noscriptUrl = `https://www.googletagmanager.com/ns.html?id=${encodeURIComponent(containerId)}`
---

{
  shouldRender && (
    <noscript>
      <iframe
        src={noscriptUrl}
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      />
    </noscript>
  )
}
