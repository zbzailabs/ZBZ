---
interface TaxonomyLink {
  href: string
  label: string
  count: number
  description?: string
}

interface TaxonomyDescription {
  label?: string
  description: string
}

interface Props {
  title: string
  items: TaxonomyLink[]
  descriptionItems?: TaxonomyDescription[]
  overviewTitle?: string
  class?: string
}

const {
  title,
  items,
  descriptionItems = items,
  overviewTitle,
  class: className = "",
} = Astro.props
const hiddenDescriptions = descriptionItems.filter(
  (item) =>
    item.description &&
    !items.some(
      (visibleItem) =>
        visibleItem.label === item.label &&
        visibleItem.description === item.description
    )
)
---

<section class={`mt-8 ${className}`}>
  <h2 class="mb-5 text-lg font-semibold text-foreground">{title}</h2>
  <div class="taxonomy-link-grid">
    {
      items.map((item) => (
        <a class="taxonomy-link" href={item.href}>
          <span class="taxonomy-link__body">
            <span class="taxonomy-link__title">{item.label}</span>
            {item.description && (
              <span class="taxonomy-link__description">
                {item.description}
              </span>
            )}
          </span>
          <span class="taxonomy-link__count" aria-label={`${item.count}`}>
            {item.count}
          </span>
        </a>
      ))
    }
  </div>
  {
    hiddenDescriptions.length > 0 && (
      <div class="sr-only">
        {overviewTitle && <p>{overviewTitle}</p>}
        {hiddenDescriptions.map((item) => (
          <p>
            {item.label} {item.description}
          </p>
        ))}
      </div>
    )
  }
</section>
