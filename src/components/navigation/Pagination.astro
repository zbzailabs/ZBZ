---
import type { PaginationPageItem } from "@/utils/pagination"

interface Props {
  prev?: string
  next?: string
  first?: string
  last?: string
  pages?: PaginationPageItem[]
  currentPage?: number
  totalPages?: number
}

const { prev, next, pages = [], currentPage, totalPages } = Astro.props
const itemClass =
  "inline-flex size-10 items-center justify-center rounded-lg bg-background/80 text-sm font-medium text-foreground shadow-sm backdrop-blur-md transition hover:-translate-y-0.5 hover:bg-accent disabled:pointer-events-none disabled:opacity-40 dark:bg-white/5"
const disabledClass = `${itemClass} opacity-35`
const pageItems =
  pages.length > 0
    ? pages
    : currentPage
      ? [{ type: "page" as const, page: currentPage, href: "#", current: true }]
      : []
---

<nav
  class="mt-10 flex items-center justify-center gap-3"
  aria-label="Pagination"
>
  {
    prev ? (
      <a class={itemClass} href={prev} rel="prev" aria-label="Previous page">
        &lsaquo;
      </a>
    ) : (
      <span
        class={disabledClass}
        aria-disabled="true"
        aria-label="Previous page"
      >
        &lsaquo;
      </span>
    )
  }
  {
    pageItems.map((item) =>
      item.type === "ellipsis" ? (
        <span class="inline-flex size-10 items-center justify-center text-sm font-medium text-muted-foreground">
          ...
        </span>
      ) : item.current ? (
        <span
          class="inline-flex size-10 items-center justify-center rounded-lg bg-foreground text-sm font-semibold text-background shadow-sm"
          aria-current="page"
          aria-label={totalPages
            ? `Page ${item.page} of ${totalPages}`
            : `Page ${item.page}`}
        >
          {item.page}
        </span>
      ) : (
        <a class={itemClass} href={item.href} aria-label={`Page ${item.page}`}>
          {item.page}
        </a>
      )
    )
  }
  {
    next ? (
      <a class={itemClass} href={next} rel="next" aria-label="Next page">
        &rsaquo;
      </a>
    ) : (
      <>
        <span class={disabledClass} aria-disabled="true" aria-label="Next page">
          &rsaquo;
        </span>
      </>
    )
  }
</nav>
