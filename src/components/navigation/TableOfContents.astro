---
import type { Locale } from "@/config/locales"
import type { TocHeading } from "@/utils/headings"

interface Props {
  lang: Locale
  headings: TocHeading[]
}

const { lang, headings } = Astro.props

const titleByLocale: Record<Locale, string> = {
  zh: "目录",
  en: "Contents",
  fr: "Sommaire",
  es: "Índice",
  ru: "Содержание",
  ja: "目次",
  ko: "목차",
  pt: "Sumário",
  de: "Inhalt",
  id: "Daftar Isi",
  ar: "المحتويات",
}

const title = titleByLocale[lang]
---

<nav
  class="toc-nav sticky top-24 flex flex-col gap-2 py-1 pl-4"
  aria-label={title}
>
  <p class="text-xs font-semibold text-muted-foreground">
    {title}
  </p>
  <ul class="flex flex-col gap-0.5 text-sm text-muted-foreground">
    {
      headings.map((heading) => (
        <li>
          <a
            class:list={[
              "block rounded-sm py-1.5 transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/40",
              heading.depth === 3 ? "pl-3 text-xs" : "",
            ]}
            href={`#${heading.slug}`}
            title={heading.text}
          >
            <span class="toc-link-label">{heading.text}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .toc-nav {
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
    scrollbar-width: none;
  }

  .toc-nav::-webkit-scrollbar {
    display: none;
  }

  .toc-link-label {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-height: 1.5;
    overflow: hidden;
    overflow-wrap: anywhere;
  }
</style>
