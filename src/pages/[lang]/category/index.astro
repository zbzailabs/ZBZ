---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/layout/PageHeader.astro"
import PageSection from "@/components/layout/PageSection.astro"
import TaxonomyLinkGrid from "@/components/navigation/TaxonomyLinkGrid.astro"
import { LOCALES, type Locale } from "@/config/locales"
import { TAXONOMY_TERMS_PER_PAGE } from "@/config/pagination"
import { SITE_CONFIG } from "@/config/site"
import { TAXONOMY } from "@/config/taxonomy"
import Pagination from "@/components/navigation/Pagination.astro"
import {
  getPageSlice,
  getPaginationLinks,
  getTotalPages,
} from "@/utils/pagination"
import { getPostsForLocale, postCategorySlug } from "@/utils/posts"
import { localePath } from "@/utils/routes"
import { t } from "@/utils/translations"

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang }, props: { lang } }))
}

const { lang } = Astro.props as { lang: Locale }
const posts = await getPostsForLocale(lang)
const countByCategory = new Map<string, number>()
for (const post of posts) {
  const categorySlug = postCategorySlug(post)
  countByCategory.set(
    categorySlug,
    (countByCategory.get(categorySlug) ?? 0) + 1
  )
}
const categoryLinks = TAXONOMY.categories
  .map((category) => ({
    href: localePath(lang, `/category/${category.slug}/`),
    label: category.labelByLocale[lang],
    count: countByCategory.get(category.slug) ?? 0,
    description: category.descriptionByLocale[lang],
  }))
const totalPages = getTotalPages(categoryLinks.length, TAXONOMY_TERMS_PER_PAGE)
const pageLinks = getPageSlice(categoryLinks, 1, TAXONOMY_TERMS_PER_PAGE)
const pagination = getPaginationLinks({
  currentPage: 1,
  totalPages,
  buildPageUrl: (page) =>
    page === 1
      ? localePath(lang, "/category/")
      : localePath(lang, `/category/page/${page}/`),
})
const categoryDescriptions = TAXONOMY.categories.map((category) => ({
  label: category.labelByLocale[lang],
  description: category.descriptionByLocale[lang],
}))
const title = t(lang, "pages.categories.title")
const seoTitle =
  lang === "en"
    ? `Content Categories and Topic Groups | ${SITE_CONFIG.name}`
    : title
const seoDescription =
  lang === "en"
    ? `Browse ${SITE_CONFIG.name} categories for startup, investing, and life articles across essays, notes, and long-term archives.`
    : t(lang, "pages.categories.description")
---

<Layout
  lang={lang}
  path="/category/"
  title={seoTitle}
  description={seoDescription}
>
  <PageSection class="py-8">
    <PageHeader
      title={title}
      description={t(lang, "pages.categories.description")}
      align="start"
    />
    <TaxonomyLinkGrid
      title={t(lang, "pages.categories.h2")}
      items={pageLinks}
      descriptionItems={categoryDescriptions}
    />
    {totalPages > 1 && (
      <Pagination
        next={pagination.next}
        last={pagination.last}
        pages={pagination.pages}
        currentPage={1}
        totalPages={totalPages}
      />
    )}
  </PageSection>
</Layout>
