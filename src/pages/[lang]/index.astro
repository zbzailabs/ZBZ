---
import Layout from "@/layouts/main.astro"
import HomeFeatureGrid from "@/components/lists/HomeFeatureGrid.astro"
import PageHeader from "@/components/layout/PageHeader.astro"
import PostCardGrid from "@/components/lists/PostCardGrid.astro"
import PostArchiveList from "@/components/lists/PostArchiveList.astro"
import PostTextCardGrid from "@/components/lists/PostTextCardGrid.astro"
import Pagination from "@/components/navigation/Pagination.astro"
import { SITE_CONFIG } from "@/config/site"
import { LOCALES, type Locale } from "@/config/locales"
import { POSTS_PER_PAGE } from "@/config/pagination"
import { getPaginationLinks, getTotalPages } from "@/utils/pagination"
import { getPostsForLocale } from "@/utils/posts"
import { t } from "@/utils/translations"

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang }, props: { lang } }))
}

const { lang } = Astro.props as { lang: Locale }
const posts = await getPostsForLocale(lang)
const lead = posts[0]
const featurePosts = posts.slice(0, 3)
const gridPosts = posts.slice(3, POSTS_PER_PAGE)
const totalPages = getTotalPages(posts.length, POSTS_PER_PAGE)
const pagination = getPaginationLinks({
  currentPage: 1,
  totalPages,
  buildPageUrl: (page) => (page === 1 ? `/${lang}/` : `/${lang}/${page}/`),
})
const homepageLayout = SITE_CONFIG.homepage.layout
const archivePosts = posts.slice(0, POSTS_PER_PAGE)
---

<Layout
  lang={lang}
  path="/"
  title={t(lang, "site.name")}
  description={t(lang, "site.description")}
  image={lead?.data.heroImage}
  dynamicGlass
>
  {
    homepageLayout === "archive" ? (
      <section
        class="mx-auto max-w-6xl px-4 py-10 sm:px-6"
        data-pagefind-ignore
        data-home-surface
      >
        <PageHeader
          title={t(lang, "pages.posts.title")}
          subtitle={t(lang, "pages.posts.totalPosts", {
            count: posts.length,
          })}
        />
        <PostArchiveList posts={archivePosts} lang={lang} />
        {totalPages > 1 && (
          <Pagination
            next={pagination.next}
            last={pagination.last}
            pages={pagination.pages}
            currentPage={1}
            totalPages={totalPages}
          />
        )}
      </section>
    ) : homepageLayout === "text" ? (
      <section
        class="mx-auto max-w-6xl px-4 py-10 sm:px-6"
        data-pagefind-ignore
        data-home-surface
      >
        <PageHeader
          title={t(lang, "pages.posts.title")}
          subtitle={t(lang, "pages.posts.totalPosts", {
            count: posts.length,
          })}
        />
        <PostTextCardGrid posts={archivePosts} />
        {totalPages > 1 && (
          <Pagination
            next={pagination.next}
            last={pagination.last}
            pages={pagination.pages}
            currentPage={1}
            totalPages={totalPages}
          />
        )}
      </section>
    ) : (
      <section
        class="mx-auto max-w-6xl px-4 py-10 sm:px-6"
        data-pagefind-ignore
        data-home-surface
      >
        <h1 class="sr-only">{t(lang, "site.name")}</h1>
        <HomeFeatureGrid posts={featurePosts} />
        {gridPosts.length > 0 && (
          <PostCardGrid
            posts={gridPosts}
            balanceLastRow
            headingLevel={3}
            class="mt-6"
          />
        )}
        {totalPages > 1 && (
          <Pagination
            next={pagination.next}
            last={pagination.last}
            pages={pagination.pages}
            currentPage={1}
            totalPages={totalPages}
          />
        )}
      </section>
    )
  }
</Layout>
