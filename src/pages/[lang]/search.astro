---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/layout/PageHeader.astro"
import PageSection from "@/components/layout/PageSection.astro"
import PagefindSearch from "@/components/features/PagefindSearch.astro"
import { LOCALES, type Locale } from "@/config/locales"
import { t } from "@/utils/translations"

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang }, props: { lang } }))
}

const { lang } = Astro.props as { lang: Locale }
const title = t(lang, "search.title")
const subtitle = t(lang, "search.subtitle")
---

<Layout lang={lang} path="/search/" title={title} description={subtitle} noindex>
  <PageSection>
    <PageHeader title={title} subtitle={subtitle} class="search-header" />
    <PagefindSearch lang={lang} class="mx-auto max-w-2xl" />
  </PageSection>
</Layout>
