---
import Layout from "@/layouts/main.astro"
import NotFoundContent from "@/components/ui/NotFoundContent.astro"
import { LOCALES, type Locale } from "@/config/locales"
import { t } from "@/utils/translations"

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang }, props: { lang } }))
}

const { lang } = Astro.props as { lang: Locale }
const title = t(lang, "notFound.title")
const description = t(lang, "notFound.message")
---

<Layout
  lang={lang}
  path="/404/"
  title={title}
  description={description}
  noindex
>
  <NotFoundContent lang={lang} />
</Layout>
