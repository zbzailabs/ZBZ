---
import Layout from "@/layouts/main.astro"
import Icon from "@/components/ui/Icon.astro"
import OptimizedPicture from "@/components/features/OptimizedPicture.astro"
import PageHeader from "@/components/layout/PageHeader.astro"
import PageSection from "@/components/layout/PageSection.astro"
import { LOCALES, type Locale } from "@/config/locales"
import { SITE_CONFIG } from "@/config/site"
import { getAuthor } from "@/utils/content"
import { getPostsForLocale, postUrl } from "@/utils/posts"
import { t } from "@/utils/translations"
import authorImage from "@/assets/author.avif"

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang }, props: { lang } }))
}

const { lang } = Astro.props as { lang: Locale }
const author = await getAuthor(lang)
const title = t(lang, "pages.author.title")
const seoTitle = lang === "en" ? `Rip Author Profile | ${SITE_CONFIG.name}` : title
const seoDescription =
  lang === "en"
    ? "Read Rip's author profile, recent publishing activity, social links, and articles on startup, investing, and life."
    : author?.data.bio
const writingActivityLabel = t(lang, "pages.author.writingActivity")
const publishedText = t(lang, "post.publishedAt")
const authorSlug = author?.data.slug ?? "default"
const authorPosts = (await getPostsForLocale(lang)).filter((post) =>
  post.data.authors.includes(authorSlug)
)
const publicationYears = [
  ...new Set(authorPosts.map((post) => post.data.pubDate.getFullYear())),
].sort((a, b) => b - a)
const activeYear = publicationYears[0] ?? new Date().getFullYear()
const previousYearsLabel = `${writingActivityLabel}: ${t(lang, "common.previous")}`
const nextYearsLabel = `${writingActivityLabel}: ${t(lang, "common.next")}`
const monthFormatter = new Intl.DateTimeFormat(lang, { month: "short" })
const dateFormatter = new Intl.DateTimeFormat(lang, {
  month: "short",
  day: "numeric",
  year: "numeric",
})
const activityMonths = Array.from({ length: 12 }, (_, month) =>
  monthFormatter.format(new Date(2026, month, 1))
)
const dateKey = (date: Date) =>
  `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}-${String(
    date.getDate()
  ).padStart(2, "0")}`
const getCalendarStart = (year: number) => {
  const calendarStart = new Date(year, 0, 1)
  calendarStart.setDate(calendarStart.getDate() - calendarStart.getDay())
  return calendarStart
}
const getCalendarEnd = (year: number) => {
  const calendarEnd = new Date(year, 11, 31)
  calendarEnd.setDate(calendarEnd.getDate() + (6 - calendarEnd.getDay()))
  return calendarEnd
}
const getWeekCount = (calendarStart: Date, calendarEnd: Date) =>
  Math.floor(
    (calendarEnd.getTime() - calendarStart.getTime()) /
      (7 * 24 * 60 * 60 * 1000)
  ) + 1
const getWeekOffset = (calendarStart: Date, date: Date) =>
  Math.floor(
    (date.getTime() - calendarStart.getTime()) / (7 * 24 * 60 * 60 * 1000)
  )
const activityGridWidth = (weekCount: number) =>
  `${Math.max(52, weekCount * 0.75 + Math.max(weekCount - 1, 0) * 0.25).toFixed(
    2
  )}rem`
const publishedByDate = authorPosts.reduce((map, post) => {
  const key = dateKey(post.data.pubDate)
  map.set(key, (map.get(key) ?? 0) + 1)
  return map
}, new Map<string, number>())
const activityLevelClass = (count: number) => {
  if (count >= 4) return "bg-[#216e39] dark:bg-[#39d353]"
  if (count === 3) return "bg-[#30a14e] dark:bg-[#26a641]"
  if (count === 2) return "bg-[#40c463] dark:bg-[#006d32]"
  if (count === 1) return "bg-[#9be9a8] dark:bg-[#0e4429]"
  return "bg-[#ebedf0] dark:bg-[#161b22]"
}
const displayYears = publicationYears.length > 0 ? publicationYears : [activeYear]
const buildActivityMonths = (year: number, weekCount: number) => {
  const calendarStart = getCalendarStart(year)

  return activityMonths.map((label, month) => {
    const monthStart = new Date(year, month, 1)
    const nextMonthStart =
      month === 11 ? getCalendarEnd(year) : new Date(year, month + 1, 1)
    const columnStart = getWeekOffset(calendarStart, monthStart) + 1
    const nextColumnStart =
      month === 11
        ? weekCount + 1
        : getWeekOffset(calendarStart, nextMonthStart) + 1

    return {
      label,
      columnStart,
      columnSpan: Math.max(1, nextColumnStart - columnStart),
    }
  })
}
const buildActivityWeeks = (year: number) => {
  const calendarStart = getCalendarStart(year)
  const calendarEnd = getCalendarEnd(year)
  const weekCount = getWeekCount(calendarStart, calendarEnd)

  return Array.from({ length: weekCount }, (_, week) =>
    Array.from({ length: 7 }, (_, day) => {
      const date = new Date(calendarStart)
      date.setDate(calendarStart.getDate() + week * 7 + day)
      const count =
        date.getFullYear() === year ? (publishedByDate.get(dateKey(date)) ?? 0) : 0

      return {
        key: dateKey(date),
        count,
        label: `${publishedText}: ${dateFormatter.format(date)}`,
        levelClass: activityLevelClass(count),
      }
    })
  )
}
const buildYearActivity = (year: number) => {
  const posts = authorPosts.filter(
    (post) => post.data.pubDate.getFullYear() === year
  )
  const counts = Object.fromEntries(
    [...publishedByDate.entries()].filter(([key]) => key.startsWith(`${year}-`))
  )

  return {
    count: posts.length,
    summary: t(lang, "pages.author.contributionsInYear", {
      count: posts.length,
      year,
    }),
    counts,
    posts: posts.slice(0, 6).map((post) => ({
      href: postUrl(post),
      title: post.data.title,
      publishedAt: `${publishedText}: ${dateFormatter.format(post.data.pubDate)}`,
    })),
  }
}
const activityByYear = Object.fromEntries(
  displayYears.map((year) => [String(year), buildYearActivity(year)])
)
const currentActivity = activityByYear[String(activeYear)]
const currentActivityWeeks = buildActivityWeeks(activeYear)
const currentActivityMonths = buildActivityMonths(activeYear, currentActivityWeeks.length)
const currentActivityGridWidth = activityGridWidth(currentActivityWeeks.length)
const currentActivityRailWidth = `calc(${currentActivityGridWidth} + 0.5rem)`
const activityDataJson = JSON.stringify(activityByYear).replace(/</g, "\\u003c")
---

<Layout
  lang={lang}
  path="/author/"
  title={seoTitle}
  description={seoDescription}
>
  <PageSection class="py-8" pagefindIgnore={false}>
    <PageHeader title={title} subtitle={author?.data.bio} />
    <article
      class="author-card mx-auto mt-16 grid max-w-5xl gap-8 rounded-[2rem] bg-background/90 p-8 sm:p-12 md:grid-cols-[11rem_minmax(0,1fr)] md:items-center lg:p-16 dark:bg-white/[0.03]"
      data-author-card
    >
      <OptimizedPicture
        src={authorImage}
        alt={author?.data.name ?? title}
        width={160}
        height={160}
        widths={[144, 160, 288, 320]}
        sizes="(max-width: 767px) 144px, 160px"
        priority
        class="mx-auto size-36 rounded-full object-cover md:size-40"
      />
      <div class="text-center md:text-left">
        <h2 class="text-5xl font-semibold text-foreground sm:text-6xl">
          {author?.data.name ?? title}
        </h2>
        <p class="mt-6 text-lg leading-8 text-muted-foreground sm:text-xl">
          {author?.data.bio}
        </p>
        <nav
          class="mt-8 flex flex-wrap justify-center gap-3 md:justify-start"
          aria-label={t(lang, "pages.author.links")}
        >
          {
            author?.data.socials.map((social) => (
              <a
                class="inline-flex size-11 items-center justify-center rounded-full bg-muted text-muted-foreground transition hover:-translate-y-0.5 hover:bg-accent hover:text-foreground"
                href={social.url}
                aria-label={social.label}
                target={social.url.startsWith("http") ? "_blank" : undefined}
                rel={social.url.startsWith("http") ? "noopener noreferrer" : undefined}
              >
                {social.label === "GitHub" ? (
                  <Icon name="github" class="size-5" dataIcon="inline-start" />
                ) : social.label === "Website" ? (
                  <Icon name="globe" class="size-5" dataIcon="inline-start" />
                ) : social.label === "RSS" ? (
                  <Icon name="rss" class="size-5" dataIcon="inline-start" />
                ) : (
                  <span class="text-xl leading-none" aria-hidden="true">
                    ×
                  </span>
                )}
              </a>
            ))
          }
        </nav>
      </div>
    </article>
    <section
      class="mx-auto mt-24 max-w-5xl rounded-[2rem] bg-muted/30 p-6 sm:p-10 dark:bg-white/[0.03]"
      data-writing-activity
      data-activity-locale={lang}
      data-activity-published-text={publishedText}
    >
      <div class="overflow-x-auto pb-2">
        <div
          class="mx-auto flex min-w-[52rem] items-center justify-between gap-6"
          style={`width: ${currentActivityRailWidth};`}
          data-activity-year-rail
        >
          <h2 class="text-2xl font-semibold text-foreground">
            {writingActivityLabel}
          </h2>
          <div
            class="flex w-full min-w-0 items-center justify-end gap-2 sm:max-w-[20.5rem]"
            data-activity-year-nav
            dir="ltr"
          >
            <button
              type="button"
              class="hidden size-10 items-center justify-center rounded-lg bg-background text-muted-foreground transition hover:bg-accent hover:text-foreground disabled:pointer-events-none disabled:opacity-35 dark:bg-white/[0.03]"
              aria-label={previousYearsLabel}
              data-activity-year-scroll="left"
            >
              <Icon name="chevron-left" class="size-4" />
            </button>
            <div
              class="flex min-w-0 max-w-[14.5rem] flex-1 snap-x gap-2 overflow-x-auto scroll-smooth [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
              data-activity-year-list
            >
              {
                displayYears.map((year, index) => (
                  <button
                    type="button"
                    class={`inline-flex h-10 w-[4.5rem] shrink-0 snap-start cursor-pointer items-center justify-center rounded-full text-sm font-semibold transition hover:bg-accent hover:text-foreground focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring ${
                      index === 0
                        ? "bg-foreground text-background"
                        : "text-muted-foreground"
                    }`}
                    aria-pressed={index === 0 ? "true" : "false"}
                    data-activity-year={year}
                  >
                    {year}
                  </button>
                ))
              }
            </div>
            <button
              type="button"
              class="hidden size-10 items-center justify-center rounded-lg bg-background text-muted-foreground transition hover:bg-accent hover:text-foreground disabled:pointer-events-none disabled:opacity-35 dark:bg-white/[0.03]"
              aria-label={nextYearsLabel}
              data-activity-year-scroll="right"
            >
              <Icon name="chevron-right" class="size-4" />
            </button>
          </div>
        </div>
        <div
          class="mx-auto mt-5 min-w-[52rem] pl-2"
          style={`width: ${currentActivityRailWidth};`}
          data-activity-grid
        >
          <div
            class="mb-3 grid gap-1 text-sm text-foreground/80"
            style={`grid-template-columns: repeat(${currentActivityWeeks.length}, minmax(0, 0.75rem)); column-gap: 0.25rem;`}
            data-activity-months
          >
            {
              currentActivityMonths.map((month) => (
                <span
                  class="min-w-0 whitespace-nowrap"
                  style={`grid-column: ${month.columnStart} / span ${month.columnSpan};`}
                >
                  {month.label}
                </span>
              ))
            }
          </div>
          <div class="flex gap-1" aria-hidden="true" data-activity-heatmap>
            {
              currentActivityWeeks.map((week) => (
                <div class="grid shrink-0 gap-1">
                  {week.map((day) => (
                    <span
                      class={`size-3 rounded-[0.2rem] ${day.levelClass}`}
                      data-day={day.key}
                      title={`${day.label}: ${day.count}`}
                    />
                  ))}
                </div>
              ))
            }
          </div>
        </div>
        <div
          class="mx-auto mt-3 flex min-w-[52rem] flex-wrap items-center justify-start gap-x-6 gap-y-2 text-sm text-muted-foreground"
          style={`width: ${currentActivityRailWidth};`}
          data-activity-legend
        >
          <div class="flex items-center gap-2">
            <span>{t(lang, "pages.author.less")}</span>
            <span class="size-3 rounded-[0.2rem] bg-muted"
            ></span>
            <span class="size-3 rounded-[0.2rem] bg-[#9be9a8] dark:bg-[#0e4429]"
            ></span>
            <span class="size-3 rounded-[0.2rem] bg-[#40c463] dark:bg-[#006d32]"
            ></span>
            <span class="size-3 rounded-[0.2rem] bg-[#30a14e] dark:bg-[#26a641]"
            ></span>
            <span class="size-3 rounded-[0.2rem] bg-[#216e39] dark:bg-[#39d353]"
            ></span>
            <span>{t(lang, "pages.author.more")}</span>
          </div>
          <p data-activity-summary>{currentActivity.summary}</p>
        </div>
        {
          currentActivity.posts.length > 0 && (
            <div
              class="mx-auto mt-8 grid min-w-[52rem] gap-3"
              style={`width: ${currentActivityRailWidth};`}
              data-author-published-list
            >
              {currentActivity.posts.map((post) => (
                <a
                  href={post.href}
                  class="grid gap-1 rounded-lg bg-background/70 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:bg-accent/70 dark:bg-white/[0.03]"
                >
                  <span class="text-xs font-medium text-muted-foreground">
                    {post.publishedAt}
                  </span>
                  <h3 class="font-semibold text-foreground">
                    {post.title}
                  </h3>
                </a>
              ))}
            </div>
          )
        }
      </div>
      <script
        is:inline
        type="application/json"
        data-activity-data
        set:html={activityDataJson}
      />
    </section>
  </PageSection>
</Layout>

<script is:inline>
  ;(() => {
    window.__authorActivityCleanup?.()
    const cleanups = []

    const setupYearNav = () => {
      document.querySelectorAll("[data-activity-year-nav]").forEach((nav) => {
        if (!(nav instanceof HTMLElement)) return
        if (nav.dataset.activityYearReady === "true") return
        nav.dataset.activityYearReady = "true"
        const list = nav.querySelector("[data-activity-year-list]")
        const prev = nav.querySelector('[data-activity-year-scroll="left"]')
        const next = nav.querySelector('[data-activity-year-scroll="right"]')
        const section = nav.closest("[data-writing-activity]")
        if (
          !(list instanceof HTMLElement) ||
          !(prev instanceof HTMLButtonElement) ||
          !(next instanceof HTMLButtonElement) ||
          !(section instanceof HTMLElement)
        ) {
          return
        }
        const heatmap = section.querySelector("[data-activity-heatmap]")
        const monthLabels = section.querySelector("[data-activity-months]")
        const yearRail = section.querySelector("[data-activity-year-rail]")
        const activityGrid = section.querySelector("[data-activity-grid]")
        const activityLegend = section.querySelector("[data-activity-legend]")
        const summary = section.querySelector("[data-activity-summary]")
        const publishedList = section.querySelector("[data-author-published-list]")
        const dataScript = section.querySelector("[data-activity-data]")
        const yearButtons = Array.from(
          list.querySelectorAll("[data-activity-year]")
        ).filter((button) => button instanceof HTMLButtonElement)
        const activityData = dataScript?.textContent
          ? JSON.parse(dataScript.textContent)
          : {}
        const activityLocale = section.dataset.activityLocale || undefined
        const publishedText = section.dataset.activityPublishedText || ""
        const dateFormatter = new Intl.DateTimeFormat(activityLocale, {
          month: "short",
          day: "numeric",
          year: "numeric",
        })
        const monthFormatter = new Intl.DateTimeFormat(activityLocale, {
          month: "short",
        })
        const activityLevelClass = (count) => {
          if (count >= 4) return "bg-[#216e39] dark:bg-[#39d353]"
          if (count === 3) return "bg-[#30a14e] dark:bg-[#26a641]"
          if (count === 2) return "bg-[#40c463] dark:bg-[#006d32]"
          if (count === 1) return "bg-[#9be9a8] dark:bg-[#0e4429]"
          return "bg-[#ebedf0] dark:bg-[#161b22]"
        }
        const dateKey = (date) =>
          `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}-${String(
            date.getDate()
          ).padStart(2, "0")}`
        const getCalendarStart = (year) => {
          const calendarStart = new Date(year, 0, 1)
          calendarStart.setDate(calendarStart.getDate() - calendarStart.getDay())
          return calendarStart
        }
        const getCalendarEnd = (year) => {
          const calendarEnd = new Date(year, 11, 31)
          calendarEnd.setDate(calendarEnd.getDate() + (6 - calendarEnd.getDay()))
          return calendarEnd
        }
        const getWeekOffset = (calendarStart, date) =>
          Math.floor(
            (date.getTime() - calendarStart.getTime()) /
              (7 * 24 * 60 * 60 * 1000)
          )
        const activityGridWidth = (weekCount) =>
          `${Math.max(52, weekCount * 0.75 + Math.max(weekCount - 1, 0) * 0.25).toFixed(
            2
          )}rem`
        const buildMonthMarkers = (year, weekCount) => {
          const calendarStart = getCalendarStart(year)
          return Array.from({ length: 12 }, (_, month) => {
            const monthStart = new Date(year, month, 1)
            const nextMonthStart =
              month === 11 ? getCalendarEnd(year) : new Date(year, month + 1, 1)
            const columnStart = getWeekOffset(calendarStart, monthStart) + 1
            const nextColumnStart =
              month === 11
                ? weekCount + 1
                : getWeekOffset(calendarStart, nextMonthStart) + 1

            return {
              label: monthFormatter.format(monthStart),
              columnStart,
              columnSpan: Math.max(1, nextColumnStart - columnStart),
            }
          })
        }
        const buildWeeks = (year, counts) => {
          const calendarStart = getCalendarStart(year)
          const calendarEnd = getCalendarEnd(year)
          const weekCount =
            Math.floor(
              (calendarEnd.getTime() - calendarStart.getTime()) /
                (7 * 24 * 60 * 60 * 1000)
            ) + 1

          return Array.from({ length: weekCount }, (_, week) =>
            Array.from({ length: 7 }, (_, day) => {
              const date = new Date(calendarStart)
              date.setDate(calendarStart.getDate() + week * 7 + day)
              const key = dateKey(date)
              const count = date.getFullYear() === year ? counts[key] || 0 : 0

              return {
                key,
                count,
                label: `${publishedText}: ${dateFormatter.format(date)}`,
                levelClass: activityLevelClass(count),
              }
            })
          )
        }

        const renderMonthLabels = (year, weekCount) => {
          if (!(monthLabels instanceof HTMLElement)) return
          monthLabels.style.gridTemplateColumns = `repeat(${weekCount}, minmax(0, 0.75rem))`
          monthLabels.style.columnGap = "0.25rem"
          monthLabels.replaceChildren(
            ...buildMonthMarkers(year, weekCount).map((month) => {
              const label = document.createElement("span")
              label.className = "min-w-0 whitespace-nowrap"
              label.style.gridColumn = `${month.columnStart} / span ${month.columnSpan}`
              label.textContent = month.label
              return label
            })
          )
        }

        const renderHeatmap = (weeks) => {
          if (!(heatmap instanceof HTMLElement)) return
          heatmap.replaceChildren(
            ...weeks.map((week) => {
              const column = document.createElement("div")
              column.className = "grid shrink-0 gap-1"
              for (const day of week) {
                const cell = document.createElement("span")
                cell.className = `size-3 rounded-[0.2rem] ${day.levelClass}`
                cell.dataset.day = day.key
                cell.title = `${day.label}: ${day.count}`
                column.append(cell)
              }
              return column
            })
          )
        }

        const renderPublishedList = (posts) => {
          if (!(publishedList instanceof HTMLElement)) return
          publishedList.replaceChildren(
            ...posts.map((post) => {
              const link = document.createElement("a")
              link.href = post.href
              link.className =
                "grid gap-1 rounded-lg bg-background/70 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:bg-accent/70 dark:bg-white/[0.03]"

              const meta = document.createElement("span")
              meta.className = "text-xs font-medium text-muted-foreground"
              meta.textContent = post.publishedAt

              const title = document.createElement("h3")
              title.className = "font-semibold text-foreground"
              title.textContent = post.title

              link.append(meta, title)
              return link
            })
          )
        }

        const setActiveYear = (year) => {
          const activity = activityData[String(year)]
          if (!activity) return

          yearButtons.forEach((button) => {
            const active = button.dataset.activityYear === String(year)
            button.setAttribute("aria-pressed", active ? "true" : "false")
            button.classList.toggle("bg-foreground", active)
            button.classList.toggle("text-background", active)
            button.classList.toggle("text-muted-foreground", !active)
            if (active) button.scrollIntoView({ block: "nearest", inline: "nearest" })
          })
          const weeks = buildWeeks(Number(year), activity.counts || {})
          const gridWidth = activityGridWidth(weeks.length)
          const railWidth = `calc(${gridWidth} + 0.5rem)`
          if (yearRail instanceof HTMLElement) yearRail.style.width = railWidth
          if (activityGrid instanceof HTMLElement) activityGrid.style.width = railWidth
          if (activityLegend instanceof HTMLElement) activityLegend.style.width = railWidth
          if (publishedList instanceof HTMLElement) publishedList.style.width = railWidth
          renderMonthLabels(Number(year), weeks.length)
          renderHeatmap(weeks)
          renderPublishedList(activity.posts)
          if (summary) summary.textContent = activity.summary
          history.replaceState(null, "", `#activity-${year}`)
        }

        const update = () => {
          const overflows = list.scrollWidth > list.clientWidth + 1
          prev.classList.toggle("hidden", !overflows)
          prev.classList.toggle("inline-flex", overflows)
          next.classList.toggle("hidden", !overflows)
          next.classList.toggle("inline-flex", overflows)
          if (!overflows) return

          const maxScroll = list.scrollWidth - list.clientWidth
          prev.disabled = list.scrollLeft <= 1
          next.disabled = list.scrollLeft >= maxScroll - 1
        }

        const getYearStep = () => {
          const yearButton = yearButtons[0]
          return yearButton ? yearButton.offsetWidth + 8 : list.clientWidth
        }
        const handlePrevClick = () => {
          list.scrollBy({ left: -getYearStep(), behavior: "smooth" })
        }
        const handleNextClick = () => {
          list.scrollBy({ left: getYearStep(), behavior: "smooth" })
        }
        const handlePointerDown = (event) => {
          if (!(event.target instanceof Element)) return
          const button = event.target.closest("[data-activity-year]")
          if (!(button instanceof HTMLButtonElement)) return
          const year = button.dataset.activityYear
          if (!year) return
          event.preventDefault()
          setActiveYear(year)
        }
        prev.addEventListener("click", handlePrevClick)
        next.addEventListener("click", handleNextClick)
        list.addEventListener("pointerdown", handlePointerDown)
        list.addEventListener("scroll", update, { passive: true })
        window.addEventListener("resize", update)
        cleanups.push(() => {
          prev.removeEventListener("click", handlePrevClick)
          next.removeEventListener("click", handleNextClick)
          list.removeEventListener("pointerdown", handlePointerDown)
          list.removeEventListener("scroll", update)
          window.removeEventListener("resize", update)
        })
        const initialYear = location.hash.match(/^#activity-(\d{4})$/)?.[1]
        if (initialYear) setActiveYear(initialYear)
        update()
      })
    }
    const cleanup = () => {
      cleanups.splice(0).forEach((fn) => fn())
    }
    const handlePageLoad = () => setupYearNav()
    const handleBeforeSwap = () => cleanup()
    document.addEventListener("astro:page-load", handlePageLoad)
    document.addEventListener("astro:before-swap", handleBeforeSwap)
    window.__authorActivityCleanup = () => {
      document.removeEventListener("astro:page-load", handlePageLoad)
      document.removeEventListener("astro:before-swap", handleBeforeSwap)
      cleanup()
    }
    setupYearNav()
  })()
</script>
