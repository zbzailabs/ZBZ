---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/layout/PageHeader.astro"
import PageSection from "@/components/layout/PageSection.astro"
import PostCardGrid from "@/components/lists/PostCardGrid.astro"
import TaxonomyPillNav from "@/components/navigation/TaxonomyPillNav.astro"
import Pagination from "@/components/navigation/Pagination.astro"
import { LOCALES, type Locale } from "@/config/locales"
import { TAXONOMY_POSTS_PER_PAGE } from "@/config/pagination"
import { TAXONOMY, getPrimaryCategories, getTag } from "@/config/taxonomy"
import { getPaginationLinks } from "@/utils/pagination"
import { getPostsByTag } from "@/utils/posts"
import { taxonomyMetaDescription, taxonomyMetaTitle } from "@/utils/seo"
import { t } from "@/utils/translations"

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const paths = []
  for (const lang of LOCALES) {
    for (const tag of TAXONOMY.tags)
      paths.push(
        ...paginate(await getPostsByTag(lang, tag.slug), {
          params: { lang, slug: tag.slug },
          props: { lang, slug: tag.slug },
          pageSize: TAXONOMY_POSTS_PER_PAGE,
        }).filter(({ props }: { props: { page: { currentPage: number } } }) =>
          props.page.currentPage > 1
        )
      )
  }
  return paths
}

const { lang, slug, page } = Astro.props as {
  lang: Locale
  slug: string
  page: {
    data: Awaited<ReturnType<typeof getPostsByTag>>
    currentPage: number
    lastPage: number
    url: { prev?: string; next?: string }
  }
}
const tag = getTag(slug)
const tagLabel = tag?.labelByLocale[lang] ?? slug
const tagDescription = tag?.descriptionByLocale[lang] ?? ""
const categories = getPrimaryCategories()
const categoryLinks = categories.map((category) => ({
  href: `/${lang}/category/${category.slug}/`,
  label: category.labelByLocale[lang],
}))
const seoTitle =
  lang === "en"
    ? taxonomyMetaTitle(tagLabel, page.currentPage)
    : `${tagLabel} ${page.currentPage}`
const seoDescription =
  lang === "en"
    ? taxonomyMetaDescription(tagLabel, tagDescription, page.currentPage)
    : tagDescription
const pagination = getPaginationLinks({
  currentPage: page.currentPage,
  totalPages: page.lastPage,
  buildPageUrl: (pageNumber) =>
    pageNumber === 1
      ? `/${lang}/tags/${slug}/`
      : `/${lang}/tags/${slug}/${pageNumber}/`,
})
---

<Layout
  lang={lang}
  path={`/tags/${slug}/${page.currentPage}/`}
  title={seoTitle}
  description={seoDescription}
  dynamicGlass
>
  <PageSection>
    <PageHeader
      eyebrow={t(lang, "pages.tags.eyebrow")}
      title={tagLabel}
      subtitle={tagDescription}
      description={t(lang, "common.pagination.pageLabel", {
        page: page.currentPage,
      })}
      stat={t(lang, "common.pagination.postsCount", {
        count: page.data.length,
      })}
    />
    <TaxonomyPillNav
      items={categoryLinks}
      label={t(lang, "pages.tags.browseCategories")}
    />
    <PostCardGrid posts={page.data} headingLevel={3} priorityFirst />
    <Pagination
      prev={page.currentPage === 2 ? `/${lang}/tags/${slug}/` : page.url.prev}
      next={page.url.next}
      first={`/${lang}/tags/${slug}/`}
      last={page.currentPage < page.lastPage
        ? `/${lang}/tags/${slug}/${page.lastPage}/`
        : undefined}
      pages={pagination.pages}
      currentPage={page.currentPage}
      totalPages={page.lastPage}
    />
  </PageSection>
</Layout>
