---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/layout/PageHeader.astro"
import PageSection from "@/components/layout/PageSection.astro"
import ProseContent from "@/components/layout/ProseContent.astro"
import PostCardGrid from "@/components/lists/PostCardGrid.astro"
import { render } from "astro:content"
import { SITE_CONFIG } from "@/config/site"
import { LOCALES, type Locale } from "@/config/locales"
import { getPage } from "@/utils/content"
import { getPostsForLocale } from "@/utils/posts"
import { t } from "@/utils/translations"

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang }, props: { lang } }))
}

const { lang } = Astro.props as { lang: Locale }
const page = await getPage(lang, "about")
const Content = page ? (await render(page)).Content : undefined
const posts = (await getPostsForLocale(lang)).slice(0, 3)
const title = t(lang, "pages.about.title")
---

<Layout
  lang={lang}
  path="/about/"
  title={title}
  description={page?.data.description}
  dynamicGlass
>
  <PageSection class="py-8" pagefindIgnore={false} data-about-page>
    <PageHeader
      title={title}
      subtitle={page?.data.description}
      class="search-header"
    />
    <div
      class="mx-auto max-w-3xl text-center text-base leading-8 text-foreground/80"
      data-about-intro
    >
      <ProseContent class="max-w-none">
        {Content ? <Content /> : <p>{SITE_CONFIG.description}</p>}
      </ProseContent>
    </div>
    {
      posts.length > 0 && (
        <PostCardGrid
          posts={posts}
          columns="three"
          priorityFirst
          class="mt-10"
          data-about-posts
        />
      )
    }
  </PageSection>
</Layout>
