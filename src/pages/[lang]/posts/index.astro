---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/layout/PageHeader.astro"
import PageSection from "@/components/layout/PageSection.astro"
import PostArchiveList from "@/components/lists/PostArchiveList.astro"
import Pagination from "@/components/navigation/Pagination.astro"
import { LOCALES, type Locale } from "@/config/locales"
import { POSTS_PER_PAGE } from "@/config/pagination"
import { getPaginationLinks, getTotalPages } from "@/utils/pagination"
import { getPostsForLocale } from "@/utils/posts"
import { t } from "@/utils/translations"

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang }, props: { lang } }))
}

const { lang } = Astro.props as { lang: Locale }
const posts = await getPostsForLocale(lang)
const pagePosts = posts.slice(0, POSTS_PER_PAGE)
const totalPages = getTotalPages(posts.length, POSTS_PER_PAGE)
const pagination = getPaginationLinks({
  currentPage: 1,
  totalPages,
  buildPageUrl: (page) =>
    page === 1 ? `/${lang}/posts/` : `/${lang}/posts/${page}/`,
})
const title = t(lang, "pages.posts.title")
const subtitle = t(lang, "pages.posts.totalPosts", { count: posts.length })
---

<Layout lang={lang} path="/posts/" title={title} description={subtitle}>
  <PageSection>
    <PageHeader title={title} subtitle={subtitle} />
    <PostArchiveList posts={pagePosts} lang={lang} />
    {totalPages > 1 && (
      <Pagination
        next={pagination.next}
        last={pagination.last}
        pages={pagination.pages}
        currentPage={1}
        totalPages={totalPages}
      />
    )}
  </PageSection>
</Layout>
