# Public canonical site URL used in generated SEO metadata.
# Forks should replace this with their own production origin.
PUBLIC_SITE_URL=https://zbz.ai

# Optional first-party asset origin for remote image URLs.
# PUBLIC_ASSET_BASE_URL=https://assets.example.com

# Optional Google Tag Manager. Disabled unless explicitly enabled.
# PUBLIC_GTM_ENABLED=false
# PUBLIC_GTM_ID=GTM-XXXXXXX

# Optional Google AdSense. Disabled unless explicitly enabled.
# PUBLIC_ADSENSE_ENABLED=false
# PUBLIC_ADSENSE_CLIENT_ID=ca-pub-0000000000000000

# Optional x402 metadata widget. Disabled unless explicitly enabled.
# This only publishes payment metadata on static builds; HTTP 402 enforcement
# requires a server middleware integration.
# Solana x402 facilitator support depends on the selected facilitator.
# PUBLIC_X402_ENABLED=false
# PUBLIC_X402_PAY_TO=YourWalletAddress
# PUBLIC_X402_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
# PUBLIC_X402_PRICE=$0.08
# PUBLIC_X402_DESCRIPTION=Voluntary x402 payment support for ZBZ content.
# PUBLIC_X402_FACILITATOR_URL=https://x402.org/facilitator

# Optional runtime x402 gateway variables for adapters such as Cloudflare
# Workers. Do not commit real wallet addresses in open-source projects.
# X402_ENABLED=false
# X402_PAY_TO=YourWalletAddress
# X402_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
# X402_PRICE=$0.08
# X402_FACILITATOR_URL=https://x402.org/facilitator
# X402_BOT_ONLY=true
# X402_BOT_SCORE_THRESHOLD=30
# X402_PROTECTED_PATTERNS=/api,/api/,/api/v1,/api/v1/,/en/posts/,/zh/posts/
